classDiagram
    class Owner {
        +string name
        +string contactPhone
        +string email
        +dict availability
        +add_owner()
        +edit_owner_info()
        +update_availability()
    }

    class Pet {
        +string name
        +string species
        +string gender
        +int age
        +add_pet()
        +edit_pet_info()
        +delete_pet()
    }

    class Task {
        +string name
        +string description
        +int durationMinutes
        +string priority
        +bool isRecurring
        +add_task()
        +edit_task()
        +delete_task()
    }

    class Scheduler {
        +date scheduleDate
        +bool allowOverlap
        +set_appointment()
        +generate_plan()
        +explain_plan()
    }

    Owner "1" --> "many" Pet : owns
    Pet "1" --> "0..*" Task : has
    Scheduler "1" --> "many" Task : schedules
    Scheduler --> Owner : uses availability
